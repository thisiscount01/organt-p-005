{
  "$schema": "deepdive-depth-visual-slot-schema/v1",
  "owner": "디자이너(아트 디렉션)",
  "consumers": ["프론트엔드(렌더 계약 도출)", "모션(구간 트리거)", "백엔드(빌드 매핑 검증)"],
  "concept": "한 줄이 초점 잡히며 확장(해상도 상승) → surface→bytecode→interpreter→memory",
  "note_for_frontend": "이 스키마는 '슬롯의 형태'만 정의한다. 각 슬롯의 실제 텍스트/유물 내용은 브랜드 스토리텔러가 채운다. 프론트는 이 스키마의 artifactTypes.fields를 그대로 콘텐츠 JSON 필드로 승격해 렌더 계약을 확정하면 된다. depth enum 4값 외(+저장 시 unassigned)는 빌드에서 거부.",

  "depthEnum": ["surface", "bytecode", "interpreter", "memory"],
  "storageOnlyExtra": ["unassigned"],

  "progressContract": {
    "source": "프론트가 스크롤 진행도 0..1 단일값 방출, 모션 소비(단일 소스)",
    "bands": {
      "surface":     [0.0, 0.25],
      "bytecode":    [0.25, 0.5],
      "interpreter": [0.5, 0.75],
      "memory":      [0.75, 1.0]
    },
    "reducedMotion": "진행도를 앵커 점프로 이산화하되 순간이동 금지 — data-depth 속성 교체 + 120ms 크로스페이드, aria-live=polite로 깊이 변화 방송."
  },

  "emphasisGrades": {
    "focal": {
      "max_per_depth": 1,
      "counts_as_block": true,
      "role": "한 뷰에서 시선이 착지하는 단 하나. 유일하게 액센트가 허용되는 요소.",
      "type_scale": "--fs-hero | --fs-display",
      "color": "--text-primary + 액센트 한 점(--accent)",
      "motion": "blur-far→blur-near, scale settle (초점이 잡힘)",
      "z": "--z-focal"
    },
    "support": {
      "max_per_depth": 2,
      "counts_as_block": true,
      "role": "focal을 뒷받침하는 실체(유물). 액센트 채움 금지 — 텍스트 위계로만.",
      "type_scale": "--fs-h2 ~ --fs-body",
      "color": "--text-primary / --text-secondary",
      "motion": "focal 이후 순차 emerge(--stagger 간격)",
      "z": "--z-support"
    },
    "ambient": {
      "max_per_depth": "제한 없음(배경 텍스처)",
      "counts_as_block": false,
      "role": "깊이의 '질감'(흐르는 바이트코드, arena 격자 등). 시선을 뺏지 않음.",
      "type_scale": "--fs-caption 이하",
      "color": "--text-tertiary / --accent-dim(≤0.16 opacity)",
      "motion": "느린 드리프트. reduced-motion 시 정지.",
      "aria": "hidden",
      "z": "--z-ambient"
    }
  },

  "firstScreenGate": {
    "max_counted_blocks": 3,
    "equal_emphasis_allowed": 0,
    "readable_within_seconds": 5,
    "rule": "focal(1) + support(≤2) = 카운트 블록 ≤3. ambient는 카운트 제외. 동급 강조(같은 크기·같은 색 무게)를 2개 이상 두지 않는다."
  },

  "artifactTypes": {
    "code-line": {
      "desc": "소스 한 줄. surface의 focal(‘print(...)’). 신택스 하이라이트 적용.",
      "fields": { "code": "string", "lang": "string(기본 'python')", "annotation": "string?(우측 주석)" },
      "render": "모노 대형, 토큰별 --code-* 색, 커서 블링크 가능"
    },
    "bytecode-dump": {
      "desc": "dis 스타일 명령 리스팅. bytecode의 focal.",
      "fields": {
        "source": "string?(원본 코드 캡션)",
        "instructions": "array<{ offset:int, opname:string, arg?:string }>",
        "caption": "string?"
      },
      "render": "3열(offset · OPNAME · arg) 모노 정렬. opname은 --code-kw."
    },
    "call-stack": {
      "desc": "인터프리터 프레임 스택. interpreter의 focal 후보.",
      "fields": {
        "frames": "array<{ func:string, module:string, line:int }>",
        "highlightIndex": "int?(현재 프레임)",
        "caption": "string?"
      },
      "render": "위→아래 프레임 카드 스택. highlight 프레임에만 --accent-line."
    },
    "memory-cell": {
      "desc": "PyObject/refcount 셀. memory의 focal.",
      "fields": {
        "label": "string(예: 'PyObject')",
        "address": "string?(예: '0x7f…')",
        "type": "string?(ob_type)",
        "refcount": "int?",
        "value": "string",
        "caption": "string?"
      },
      "render": "격자 셀. refcount는 --code-amber 뱃지."
    },
    "commit": {
      "desc": "git 커밋 유물(CPython 기여 등). 사고의 궤적.",
      "fields": { "hash": "string(7자)", "subject": "string", "repo": "string?", "date": "string?" },
      "render": "‘●─ hash subject’ 로그 라인. hash는 --code-amber."
    },
    "slide": {
      "desc": "발표/슬라이드 유물(PyCon 연사 등).",
      "fields": { "event": "string", "year": "string", "title": "string", "role": "string", "url": "string?" },
      "render": "슬라이드 카드(16:9 프레임 + 제목 오버레이). 얼굴 사진 대체물."
    },
    "trace": {
      "desc": "문제풀이/성취 흔적(백준 티어, 삼성 B, 수상, 경력).",
      "fields": { "kind": "string(예:'algorithm'|'career'|'award'|'cert')", "label": "string", "value": "string", "detail": "string?" },
      "render": "라벨 + 강조 수치(value는 --accent 또는 --code-amber)."
    },
    "prose": {
      "desc": "서사 텍스트(스토리텔러 소유 내용). 각 깊이의 감정선을 잇는 문장.",
      "fields": { "heading": "string?", "body": "string" },
      "render": "--font-body, max-width --measure, --lh-body."
    },
    "spec-badge": {
      "desc": "정체성/자격 칩(예: 'Python 개발자', '정보처리산업기사').",
      "fields": { "label": "string", "value": "string?" },
      "render": "pill, --line 테두리, --text-secondary."
    },
    "link-out": {
      "desc": "외부 글/블로그/투고 링크(요즘IT 등).",
      "fields": { "label": "string", "href": "string" },
      "render": "밑줄 링크 + ↗, --accent hover."
    }
  },

  "depths": [
    {
      "id": "surface",
      "order": 0,
      "progressBand": [0.0, 0.25],
      "label": { "ko": "표면", "code": "surface" },
      "microLabel": "00 · SURFACE",
      "tagline_slot": "우리가 매일 쓰는 한 줄",
      "bg": "--bg-surface",
      "accentUsage": "최소 — 커서 1점 또는 토큰 1개에만",
      "focalArtifactType": "code-line",
      "allowedArtifactTypes": ["code-line", "spec-badge", "prose"],
      "maxSupport": 2,
      "ambientHint": "타이핑 커서, 아주 옅은 격자",
      "motionNote": "히어로 한 줄이 흐릿하게 떠 있다가 초점이 잡힘",
      "intent": "5초 안에 ‘이 사람 깊다’의 씨앗 — 가장 단순한 한 줄"
    },
    {
      "id": "bytecode",
      "order": 1,
      "progressBand": [0.25, 0.5],
      "label": { "ko": "바이트코드", "code": "bytecode" },
      "microLabel": "01 · BYTECODE",
      "tagline_slot": "표면 아래 — 컴파일된 명령들",
      "bg": "--bg-bytecode",
      "accentUsage": "opname/포커스 명령에 한정",
      "focalArtifactType": "bytecode-dump",
      "allowedArtifactTypes": ["bytecode-dump", "slide", "link-out", "prose"],
      "maxSupport": 2,
      "ambientHint": "배경에 흐르는 opcode 스트림(aria-hidden)",
      "motionNote": "code-line이 dis 명령들로 분해(형태변형)",
      "intent": "‘표면 아래를 본다’ — PyCon print 내부동작 연사가 여기 유물로"
    },
    {
      "id": "interpreter",
      "order": 2,
      "progressBand": [0.5, 0.75],
      "label": { "ko": "인터프리터", "code": "interpreter" },
      "microLabel": "02 · INTERPRETER",
      "tagline_slot": "실행을 돌리는 루프 — 그리고 그가 바꾼 것",
      "bg": "--bg-interpreter",
      "accentUsage": "현재 프레임/그가 추가한 코드 라인에 한정",
      "focalArtifactType": "call-stack",
      "allowedArtifactTypes": ["call-stack", "code-line", "commit", "prose"],
      "maxSupport": 2,
      "ambientHint": "ceval 루프 의사코드 드리프트",
      "motionNote": "프레임이 아래로 쌓이며 깊이 진입",
      "intent": "언어 자체에 손을 댄 사람 — defer 예약어 구현/CPython"
    },
    {
      "id": "memory",
      "order": 3,
      "progressBand": [0.75, 1.0],
      "label": { "ko": "메모리", "code": "memory" },
      "microLabel": "03 · MEMORY",
      "tagline_slot": "가장 깊은 곳 — 객체와 참조가 사는 자리",
      "bg": "--bg-memory",
      "accentUsage": "refcount·핵심 수치에 한정",
      "focalArtifactType": "memory-cell",
      "allowedArtifactTypes": ["memory-cell", "trace", "spec-badge", "prose"],
      "maxSupport": 2,
      "ambientHint": "arena 격자(메모리 셀)",
      "motionNote": "셀 격자가 조리개처럼 선명해지며 심연 도달",
      "intent": "경외 → 코다 CTA(‘1시간 이야기하고 싶다’) 직전. 백준 2.5%/DICOM 유물",
      "coda": {
        "desc": "4깊이 종료 직후의 비-depth UI. 감정선의 착지점.",
        "headline_slot": "1시간 이야기하고 싶어지는 문장",
        "cta_slot": "딥다이브 인테이크로 연결(‘당신의 질문을 던져보세요’)",
        "render": "focal 1개(문장) + primary 버튼(--accent-strong 채움). depth 카운트 아님."
      }
    }
  ],

  "intakeTone": {
    "desc": "딥다이브 인테이크 화면의 시각 톤(디자이너 소유, 프론트 구현).",
    "layout": "한 번에 질문 하나. 화면 중앙, 여백 지배(≥70%).",
    "prompt": "--font-code, --fs-display, --text-primary. 커서는 --accent 블링크(열면 첫 질문에 autofocus).",
    "dropzone": "점선 --accent-line 테두리, ‘소스·이야기를 여기로 던지세요’. 드래그 오버 시 --accent-dim 채움.",
    "card": "던진 입력은 유물 카드(--surface-raised)로 낙관적 적재 + emerge 모션. depth=unassigned 허용.",
    "rhythm": "한 문항 답→다음 문항 크로스페이드. 진행 눈금은 우측 미세 점(현재만 점등)."
  }
}
